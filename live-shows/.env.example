# YouTube API credentials for songs-for-my-funeral live-shows scripts
# -------------------------------------------------------------------
# Copy this file to .env (in the same live-shows/ directory) and fill
# in your values. .env is gitignored and must never be committed.
#
# See utils/HOWTO.md → "YouTube API credentials" for setup instructions.

# YouTube Data API key (read-only, used by youtube_fetch.py)
# Get from: Google Cloud Console → APIs & Services → Credentials → API Keys
YOUTUBE_API_KEY=your_api_key_here

# OAuth client secrets file (used by youtube_create_playlists.py)
# Download from: Google Cloud Console → Credentials → OAuth 2.0 Client IDs
# Default assumes the file is in the live-shows/ directory alongside the scripts.
YOUTUBE_CLIENT_SECRETS=client_secrets.json

# OAuth token cache file (auto-generated on first auth run — do not edit manually)
# Default is fine; change only if you want to store it elsewhere.
YOUTUBE_TOKEN_FILE=token.json

# Spotify API credentials (used by artists_youtube_spotify.py)
# Create a free app at: https://developer.spotify.com/dashboard
# Set any Redirect URI (e.g. http://localhost) — it is not used by this script.
# Copy the Client ID and Client Secret from the app's settings page.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
